+
+// ============================================================================
+// 7. TickOperation
+// ============================================================================
+//
+// Purpose: Represents a single unit of work that can be dispatched
+// to a worker thread. Wraps a scheduled tick, entity tick, etc.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.core.BlockPos;
+
+public abstract class TickOperation {
+
+    /**
+     * Create an OperationId for this operation.
+     */
+    public abstract OperationId createId(int threadIndex);
+
+    // --- Concrete subtypes ---
+
+    public static class BlockTickOp extends TickOperation {
+        private final BlockPos pos;
+        private final net.minecraft.world.level.block.Block block;
+
+        public BlockTickOp(BlockPos pos, net.minecraft.world.level.block.Block block) {
+            this.pos = pos;
+            this.block = block;
+        }
+
+        @Override
+        public OperationId createId(int threadIndex) {
+            return OperationId.blockTick(this.pos, threadIndex);
+        }
+
+        public BlockPos getPos() { return this.pos; }
+        public net.minecraft.world.level.block.Block getBlock() { return this.block; }
+    }
+
+    public static class FluidTickOp extends TickOperation {
+        private final BlockPos pos;
+        private final net.minecraft.world.level.material.Fluid fluid;
+
+        public FluidTickOp(BlockPos pos, net.minecraft.world.level.material.Fluid fluid) {
+            this.pos = pos;
+            this.fluid = fluid;
+        }
+
+        @Override
+        public OperationId createId(int threadIndex) {
+            return OperationId.fluidTick(this.pos, threadIndex);
+        }
+
+        public BlockPos getPos() { return this.pos; }
+        public net.minecraft.world.level.material.Fluid getFluid() { return this.fluid; }
+    }
+
+    public static class EntityTickOp extends TickOperation {
+        private final net.minecraft.world.entity.Entity entity;
+
+        public EntityTickOp(net.minecraft.world.entity.Entity entity) {
+            this.entity = entity;
+        }
+
+        @Override
+        public OperationId createId(int threadIndex) {
+            return OperationId.entityTick(this.entity.getId(), threadIndex);
+        }
+
+        public net.minecraft.world.entity.Entity getEntity() { return this.entity; }
+    }
+
+    public static class BlockEntityTickOp extends TickOperation {
+        private final BlockPos pos;
+        private final net.minecraft.world.level.block.entity.TickingBlockEntity ticker;
+
+        public BlockEntityTickOp(BlockPos pos,
+                                 net.minecraft.world.level.block.entity.TickingBlockEntity ticker) {
+            this.pos = pos;
+            this.ticker = ticker;
+        }
+
+        @Override
+        public OperationId createId(int threadIndex) {
+            return OperationId.blockEntityTick(this.pos, threadIndex);
+        }
+
+        public BlockPos getPos() { return this.pos; }
+        public net.minecraft.world.level.block.entity.TickingBlockEntity getTicker() {
+            return this.ticker;
+        }
+    }
+}
diff --git a/net/minecraft/server/level/mica/TrackedOverlay.java b/net/minecraft/server/level/mica/TrackedOverlay.java
new file mode 100644
index 0000000000000000000000000000000000000000..4cc6afede00a2b37f59f03c7ab28c7d073622a1d
--- /dev/null
+++ b/net/minecraft/server/level/mica/TrackedOverlay.java
@@ -0,0 +1,216 @@
+
+
+// ============================================================================
+// 2. TrackedOverlay
+// ============================================================================
+//
+// Purpose: Thread-local read-write layer on top of the snapshot.
+// Reads check the overlay first, then fall through to the snapshot.
+// Writes go into the overlay only.
+// All reads and writes are tracked for provenance (which operation
+// caused them) so we can do precise conflict detection.
+//
+// Each worker thread gets one of these. Operations on the same thread
+// share the overlay, which means intra-thread cascades (neighborChanged)
+// naturally see each other's writes — exactly like vanilla's serial behavior.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.world.level.BlockGetter;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.material.FluidState;
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import java.util.HashSet;
+import java.util.Set;
+import org.jspecify.annotations.Nullable;
+
+public class TrackedOverlay implements BlockGetter {
+
+    private WorldSnapshot snapshot;
+
+    // Block state writes: packed position -> new state
+    // Using long key for performance (BlockPos.asLong())
+    private final Long2ObjectMap<BlockState> blockWrites = new Long2ObjectOpenHashMap<>();
+
+    // Provenance tracking: for each written position, which operation wrote it
+    private final Long2ObjectMap<OperationId> writeProvenance = new Long2ObjectOpenHashMap<>();
+
+    // Read tracking: for the current operation, which positions were read
+    // Reset when we start a new operation on this thread
+    private final Long2ObjectMap<Set<OperationId>> readProvenance = new Long2ObjectOpenHashMap<>();
+
+    // The operation currently being executed on this thread
+    private @Nullable OperationId currentOperation;
+
+    public DeferredEffects deferredEffects;
+
+    // Stats for debugging/profiling
+    private int readCount = 0;
+    private int writeCount = 0;
+    private int overlayHitCount = 0;
+
+    // Thread index for this overlay
+    private int threadIndex;
+
+    // Record of every block that was random-ticked, so we can re-run specific ones
+    private final java.util.List<TickRecord> tickRecords = new java.util.ArrayList<>();
+
+    public record ReadRecord(OperationId opId, long pos) {}
+
+    private final java.util.List<ReadRecord> operationReads = new java.util.ArrayList<>();
+    private final it.unimi.dsi.fastutil.longs.LongOpenHashSet readPositions = new it.unimi.dsi.fastutil.longs.LongOpenHashSet();
+
+    public TrackedOverlay(WorldSnapshot snapshot) {
+        this.snapshot = snapshot;
+    }
+
+
+    public void setThreadIndex(int threadIndex) {
+        this.threadIndex = threadIndex;
+    }
+
+    public int getThreadIndex() {
+        return this.threadIndex;
+    }
+
+    public void recordTick(OperationId opId, BlockPos pos) {
+        this.tickRecords.add(new TickRecord(opId, pos.immutable()));
+    }
+
+    public java.util.List<TickRecord> getTickRecords() {
+        return this.tickRecords;
+    }
+
+    public record TickRecord(OperationId opId, BlockPos pos) {}
+
+    /**
+     * Set the current operation context.
+     * Called before each operation starts executing on this thread.
+     * All subsequent reads/writes are attributed to this operation.
+     */
+    public void setCurrentOperation(OperationId operation) {
+        this.currentOperation = operation;
+    }
+
+    public void setSnapshot(WorldSnapshot snapshot) {
+        this.snapshot = snapshot;
+    }
+
+    @Override
+    public BlockState getBlockState(BlockPos pos) {
+        long packed = pos.asLong();
+        this.readCount++;
+        this.readPositions.add(packed);
+
+        if (this.currentOperation != null) {
+            this.operationReads.add(new ReadRecord(this.currentOperation, packed));
+        }
+
+        BlockState overlayState = this.blockWrites.get(packed);
+        if (overlayState != null) {
+            this.overlayHitCount++;
+            return overlayState;
+        }
+
+        return this.snapshot.getBlockState(pos);
+    }
+
+    @Override
+    public FluidState getFluidState(BlockPos pos) {
+        return this.getBlockState(pos).getFluidState();
+    }
+
+    @Override
+    public @Nullable FluidState getFluidIfLoaded(BlockPos pos) {
+        return this.getFluidState(pos);
+    }
+
+    @Override
+    public @Nullable BlockEntity getBlockEntity(BlockPos pos) {
+        // TODO: overlay block entity state
+        return this.snapshot.getBlockEntity(pos);
+    }
+
+    @Override
+    public @Nullable BlockState getBlockStateIfLoaded(BlockPos pos) {
+        return this.getBlockState(pos);
+    }
+
+    @Override
+    public int getHeight() {
+        return this.snapshot.getHeight();
+    }
+
+    @Override
+    public int getMinY() {
+        return this.snapshot.getMinY();
+    }
+
+    /**
+     * Write a block state change into the overlay.
+     * This does NOT modify the snapshot or the live world.
+     * The change is only visible to subsequent reads on THIS thread.
+     */
+    public void setBlockState(BlockPos pos, BlockState state) {
+        long packed = pos.asLong();
+        this.blockWrites.put(packed, state);
+        this.writeCount++;
+
+        if (this.currentOperation != null) {
+            this.writeProvenance.put(packed, this.currentOperation);
+        }
+    }
+
+    /**
+     * Check if this overlay has written to a specific position.
+     */
+    public boolean hasWrite(long packedPos) {
+        return this.blockWrites.containsKey(packedPos);
+    }
+
+    // --- Accessors for merge phase ---
+
+    public Long2ObjectMap<BlockState> getBlockWrites() {
+        return this.blockWrites;
+    }
+
+    public Long2ObjectMap<OperationId> getWriteProvenance() {
+        return this.writeProvenance;
+    }
+
+    public Long2ObjectMap<Set<OperationId>> getReadProvenance() {
+        return this.readProvenance;
+    }
+
+    public int getReadCount() { return this.readCount; }
+    public int getWriteCount() { return this.writeCount; }
+    public int getOverlayHitCount() { return this.overlayHitCount; }
+
+    public it.unimi.dsi.fastutil.longs.LongOpenHashSet getReadPositions() {
+        return this.readPositions;
+    }
+
+    public java.util.List<ReadRecord> getOperationReads() {
+        return this.operationReads;
+    }
+
+    /**
+     * Clear the overlay for reuse.
+     */
+    public void clear() {
+        this.blockWrites.clear();
+        this.writeProvenance.clear();
+        this.readProvenance.clear();
+        this.readPositions.clear();
+        this.operationReads.clear();
+        this.currentOperation = null;
+        this.threadIndex = 0;
+        this.tickRecords.clear();
+        this.readCount = 0;
+        this.writeCount = 0;
+        this.overlayHitCount = 0;
+    }
+}
diff --git a/net/minecraft/server/level/mica/WorldSnapshot.java b/net/minecraft/server/level/mica/WorldSnapshot.java
new file mode 100644
index 0000000000000000000000000000000000000000..4ff12015810d1f21e664d81292d7b835bd5dbb6e
--- /dev/null
+++ b/net/minecraft/server/level/mica/WorldSnapshot.java
@@ -0,0 +1,178 @@
+// ============================================================================
+// WorldSnapshot
+// ============================================================================
+//
+// Purpose: Immutable view of world state at tick start.
+// All parallel workers read from this. Nobody writes to it.
+//
+// Key design decision: We don't deep-copy the world. We use Copy-on-Write
+// at the chunk section level. At tick start, we flag all loaded chunk
+// sections as COW. If the merge phase (or anything else) needs to write
+// to a section, it copies it first. Snapshot readers always see the
+// original data.
+//
+// Implements BlockGetter so existing Minecraft code that reads block state
+// can accept it without modification.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.world.level.BlockGetter;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.chunk.LevelChunk;
+import net.minecraft.world.level.chunk.LevelChunkSection;
+import net.minecraft.world.level.material.FluidState;
+import net.minecraft.server.level.ServerLevel;
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import org.jspecify.annotations.Nullable;
+
+public class WorldSnapshot implements BlockGetter {
+
+    // Snapshotted chunk sections, keyed by chunk pos
+    // Each entry holds references to the section arrays AT THE TIME of snapshot
+    // These references become stale if the live world modifies them,
+    // but that's the point — we want the old data
+    private final Long2ObjectMap<LevelChunkSection[]> sectionSnapshots;
+
+    // Reference to the live world for data we don't snapshot
+    // (biomes, heightmaps, light — these change rarely mid-tick
+    // and are expensive to snapshot)
+    private final ServerLevel level;
+
+    // The game tick this snapshot represents
+    private final long gameTick;
+
+    private WorldSnapshot(ServerLevel level, long gameTick,
+                          Long2ObjectMap<LevelChunkSection[]> sectionSnapshots) {
+        this.level = level;
+        this.gameTick = gameTick;
+        this.sectionSnapshots = sectionSnapshots;
+    }
+
+    /**
+     * Create a snapshot of the current world state.
+     *
+     * This is O(number of loaded chunks) but very fast —
+     * we're just copying array references, not block data.
+     * Each LevelChunkSection is ~8KB of palette-compressed data;
+     * we only reference it, not copy it.
+     */
+    public static WorldSnapshot capture(ServerLevel level) {
+        long gameTick = level.getGameTime();
+        Long2ObjectMap<LevelChunkSection[]> sections = new Long2ObjectOpenHashMap<>();
+
+        // Iterate all entity-ticking chunks (the ones that get ticked)
+        // Paper gives us direct array access for performance
+        var tickingChunks = level.moonrise$getEntityTickingChunks();
+        LevelChunk[] raw = tickingChunks.getRawDataUnchecked();
+        int size = tickingChunks.size();
+
+        for (int i = 0; i < size; i++) {
+            LevelChunk chunk = raw[i];
+            long chunkKey = chunk.getPos().toLong();
+
+            // Snapshot the section array reference
+            // IMPORTANT: We store a reference to the SAME array.
+            // If we later need COW, we clone at that point.
+            LevelChunkSection[] original = chunk.getSections();
+            LevelChunkSection[] copy = new LevelChunkSection[original.length];
+            System.arraycopy(original, 0, copy, 0, original.length);
+            sections.put(chunkKey, copy);
+        }
+
+        return new WorldSnapshot(level, gameTick, sections);
+    }
+
+    @Override
+    public @Nullable BlockState getBlockState(BlockPos pos) {
+        int chunkX = pos.getX() >> 4;
+        int chunkZ = pos.getZ() >> 4;
+        long chunkKey = ((long) chunkX & 0xFFFFFFFFL) | (((long) chunkZ & 0xFFFFFFFFL) << 32);
+
+        LevelChunkSection[] sections = this.sectionSnapshots.get(chunkKey);
+        if (sections == null) {
+            // Chunk not in snapshot — fall back to live world
+            // This handles edge cases where an operation reads beyond
+            // the ticking chunk radius
+
+            // Bypass Level.getBlockState() to avoid hitting the Mica overlay intercept
+            LevelChunk chunk = this.level.getChunkSource().getChunkAtIfLoadedImmediately(pos.getX() >> 4, pos.getZ() >> 4);
+            if (chunk != null) {
+                return chunk.getBlockState(pos);
+            }
+            return net.minecraft.world.level.block.Blocks.AIR.defaultBlockState();
+        }
+
+        int sectionIndex = level.getSectionIndex(pos.getY());
+        if (sectionIndex < 0 || sectionIndex >= sections.length) {
+            // Out of world bounds
+            return net.minecraft.world.level.block.Blocks.AIR.defaultBlockState();
+        }
+
+        LevelChunkSection section = sections[sectionIndex];
+        return section.getBlockState(
+            pos.getX() & 15,
+            pos.getY() & 15,
+            pos.getZ() & 15
+        );
+    }
+
+    @Override
+    public @Nullable FluidState getFluidState(BlockPos pos) {
+        BlockState state = this.getBlockState(pos);
+        return state.getFluidState();
+    }
+
+    @Override
+    public @Nullable FluidState getFluidIfLoaded(BlockPos pos) {
+        return this.getFluidState(pos);
+    }
+
+    @Override
+    public @Nullable BlockEntity getBlockEntity(BlockPos pos) {
+        // Block entities are more complex — for now, delegate to live world
+        // This is safe for snapshot reads because block entity state
+        // doesn't change during the compute phase
+        // TODO: Snapshot block entity state for full isolation
+        return this.level.getBlockEntity(pos);
+    }
+
+    @Override
+    public @Nullable BlockState getBlockStateIfLoaded(BlockPos pos) {
+        return this.getBlockState(pos);
+    }
+
+    @Override
+    public int getHeight() {
+        return this.level.getHeight();
+    }
+
+    @Override
+    public int getMinY() {
+        return this.level.getMinY();
+    }
+
+    public long getGameTick() {
+        return this.gameTick;
+    }
+
+    public ServerLevel getLevel() {
+        return this.level;
+    }
+}
+
+
+
+
+
+
+
+
+
+
+
+
+
+
