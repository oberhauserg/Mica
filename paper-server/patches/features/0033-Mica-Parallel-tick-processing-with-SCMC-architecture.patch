+            this.micaOverlays[t].deferredEffects = new net.minecraft.server.level.mica.DeferredEffects();
+        }
+
+        // Build a mapping from OperationId source position to chunk index
+        // so we can re-run tainted chunks in the converge phase
+        final it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap chunkPosToIndex =
