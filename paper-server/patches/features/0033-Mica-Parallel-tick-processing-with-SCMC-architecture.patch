+
         java.util.Objects.checkFromToIndex(0, size, raw.length);
-        for (int i = 0; i < size; ++i) {
-            world.tickChunk(raw[i], randomTickSpeed);
+        for (int i = 0; i < size; i++) {
+            chunkPosToIndex.put(raw[i].getPos().toLong(), i);
+        }
+
+        // Dispatch to thread pool
+        final int batchSize = Math.max(1, (size + MICA_THREAD_COUNT - 1) / MICA_THREAD_COUNT);
+        final java.util.concurrent.CountDownLatch latch = new java.util.concurrent.CountDownLatch(MICA_THREAD_COUNT);
+        final java.util.concurrent.atomic.AtomicReference<Throwable> error = new java.util.concurrent.atomic.AtomicReference<>();
 
-            // call mid-tick tasks for chunk system
-            if ((i & 7) == 0) {
-                ((ca.spottedleaf.moonrise.patches.chunk_system.server.ChunkSystemMinecraftServer)this.level.getServer()).moonrise$executeMidTickTasks();
+        for (int t = 0; t < MICA_THREAD_COUNT; t++) {
+            final int threadIndex = t;
+            final int start = t * batchSize;
+            final int end = Math.min(start + batchSize, size);
+
+            if (start >= size) {
+                latch.countDown();
                 continue;
             }
+
+            final net.minecraft.server.level.mica.TrackedOverlay overlay = this.micaOverlays[t];
+
+            MICA_POOL.execute(() -> {
+                try {
+                    ca.spottedleaf.moonrise.common.util.TickThread.micaParallelPhase.set(Boolean.TRUE);
+                    world.micaOverlay.set(overlay);
+                    CollectingNeighborUpdater threadUpdater = new CollectingNeighborUpdater(
+                        world,
+                        world.getServer().getMaxChainedNeighborUpdates());
+                    Level.micaNeighborUpdater.set(threadUpdater);
+
+                    net.minecraft.world.level.Level.micaDeferredStatic.set(overlay.deferredEffects);
+                    try {
+                        overlay.setThreadIndex(threadIndex);
+                        for (int i = start; i < end; i++) {
+                            world.tickChunk(raw[i], randomTickSpeed);
+                        }
+                    } finally {
+                        world.micaOverlay.remove();
+                        net.minecraft.world.level.Level.micaDeferredStatic.remove();
+                    }
+                } catch (Throwable t1) {
+                    error.compareAndSet(null, t1);
+                    MICA_LOGGER.error("[Mica] Error in parallel chunk tick on thread {}", threadIndex, t1);
+                } finally {
+                    ca.spottedleaf.moonrise.common.util.TickThread.micaParallelPhase.set(Boolean.FALSE);
+                    world.micaOverlay.remove();
+                    Level.micaNeighborUpdater.remove();
+                    net.minecraft.world.level.Level.micaDeferredStatic.remove();
+                    latch.countDown();
+                }
+            });
+        }
+
+        try {
+            latch.await();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+        }
+
+        long timeCompute = System.nanoTime();
+
+        // Check for errors
+        if (error.get() != null) {
+            MICA_LOGGER.error("[Mica] Parallel tick failed, skipping merge/apply");
+            return;
+        }
+
+        // --- Phase 3: Merge ---
+        java.util.List<net.minecraft.server.level.mica.TrackedOverlay> activeOverlays =
+            java.util.Arrays.asList(this.micaOverlays).subList(0, MICA_THREAD_COUNT);
+
+        net.minecraft.server.level.mica.OverlayMerger.MergeResult mergeResult =
+            net.minecraft.server.level.mica.OverlayMerger.merge(activeOverlays);
+
+        long timeMerge = System.nanoTime();
+
+        // --- Phase 4: Converge (re-run tainted operations) ---
+        int rerunCount = 0;
+
+        if (!mergeResult.taintedOperations().isEmpty()) {
+            net.minecraft.server.level.mica.TrackedOverlay rerunOverlay =
+                new net.minecraft.server.level.mica.TrackedOverlay(snapshot);
+            rerunOverlay.deferredEffects = new net.minecraft.server.level.mica.DeferredEffects();
+
+            // Apply clean writes so re-runs see non-conflicting results
+            for (var entry : mergeResult.cleanWrites().long2ObjectEntrySet()) {
+                rerunOverlay.setBlockState(
+                    net.minecraft.core.BlockPos.of(entry.getLongKey()),
+                    entry.getValue());
+            }
+
+            // Collect tainted block positions from all overlays' tick records
+            java.util.List<net.minecraft.server.level.mica.TrackedOverlay.TickRecord> toRerun =
+                new java.util.ArrayList<>();
+
+            for (int t = 0; t < MICA_THREAD_COUNT; t++) {
+                for (net.minecraft.server.level.mica.TrackedOverlay.TickRecord record :
+                    this.micaOverlays[t].getTickRecords()) {
+                    if (mergeResult.taintedOperations().contains(record.opId())) {
+                        toRerun.add(record);
+                    }
+                }
+            }
+
+            // Re-run individual tainted block ticks serially
+            world.micaOverlay.set(rerunOverlay);
+            net.minecraft.world.level.Level.micaDeferredStatic.set(rerunOverlay.deferredEffects);
+            try {
+                for (net.minecraft.server.level.mica.TrackedOverlay.TickRecord record : toRerun) {
+                    rerunOverlay.setCurrentOperation(record.opId());
+                    net.minecraft.core.BlockPos pos = record.pos();
+                    net.minecraft.world.level.block.state.BlockState state = rerunOverlay.getBlockState(pos);
+
+                    if (record.opId().type() == net.minecraft.server.level.mica.OperationType.RANDOM_TICK) {
+                        state.randomTick(world, pos, world.random);
+                    } else if (record.opId().type() == net.minecraft.server.level.mica.OperationType.FLUID_TICK) {
+                        net.minecraft.world.level.material.FluidState fluidState = state.getFluidState();
+                        if (fluidState.isRandomlyTicking()) {
+                            fluidState.randomTick(world, pos, world.random);
+                        }
+                    }
+                    rerunCount++;
+                }
+            } finally {
+                world.micaOverlay.remove();
+                net.minecraft.world.level.Level.micaDeferredStatic.remove();
+            }
+
+            // Merge rerun writes into final result
+            for (var entry : rerunOverlay.getBlockWrites().long2ObjectEntrySet()) {
+                mergeResult.cleanWrites().put(entry.getLongKey(), entry.getValue());
+            }
+
+            if (!rerunOverlay.deferredEffects.isEmpty()) {
+                rerunOverlay.deferredEffects.apply(world);
+            }
         }
+
+        long timeConverge = System.nanoTime();
+
+        // --- Apply clean writes to live world ---
+        for (var entry : mergeResult.cleanWrites().long2ObjectEntrySet()) {
+            net.minecraft.core.BlockPos pos = net.minecraft.core.BlockPos.of(entry.getLongKey());
+            net.minecraft.world.level.block.state.BlockState state = entry.getValue();
+            world.setBlock(pos, state, net.minecraft.world.level.block.Block.UPDATE_ALL);
+        }
+
+        // Apply deferred effects from parallel phase on main thread
+        for (int t = 0; t < MICA_THREAD_COUNT; t++) {
+            net.minecraft.server.level.mica.DeferredEffects deferred = this.micaOverlays[t].deferredEffects;
+            if (deferred != null && !deferred.isEmpty()) {
+                deferred.apply(world);
+            }
+        }
+
+        long timeApply = System.nanoTime();
+
+        // --- Stats ---
+        for (int t = 0; t < MICA_THREAD_COUNT; t++) {
+            micaCumulativeReads += this.micaOverlays[t].getReadCount();
+            micaCumulativeWrites += this.micaOverlays[t].getWriteCount();
+        }
+        micaCumulativeConflicts += mergeResult.conflictCount();
+        micaCumulativeTainted += mergeResult.taintedOperationCount();
+        micaCumulativeReruns += rerunCount;
+
+        world.micaTickCount++;
+        if (world.micaTickCount % 200 == 0) {
+            int totalReads = 0, totalWrites = 0, totalDeferred = 0;
+            for (int t = 0; t < MICA_THREAD_COUNT; t++) {
+                totalReads += this.micaOverlays[t].getReadCount();
+                totalWrites += this.micaOverlays[t].getWriteCount();
+                if (this.micaOverlays[t].deferredEffects != null) {
+                    totalDeferred += this.micaOverlays[t].deferredEffects.getSkippedEntitySpawnCount()
+                        + this.micaOverlays[t].deferredEffects.getSkippedEventCount();
+                }
+            }
+
+            double msSnapshot = (timeSnapshot - timeStart) / 1_000_000.0;
+            double msCompute = (timeCompute - timeSnapshot) / 1_000_000.0;
+            double msMerge = (timeMerge - timeCompute) / 1_000_000.0;
+            double msConverge = (timeConverge - timeMerge) / 1_000_000.0;
+            double msApply = (timeApply - timeConverge) / 1_000_000.0;
+            double msTotal = (timeApply - timeStart) / 1_000_000.0;
+
+            MICA_LOGGER.info("{} threads | {} chunks | {} reads, {} writes | {} conflicts, {} tainted, {} re-runs",
+                MICA_THREAD_COUNT, size, micaCumulativeReads, micaCumulativeWrites,
+                micaCumulativeConflicts, micaCumulativeTainted, micaCumulativeReruns);
+            MICA_LOGGER.info("Timing: {}ms total | snapshot {}ms | compute {}ms | merge {}ms | converge {}ms | apply {}ms",
+                String.format("%.2f", msTotal),
+                String.format("%.2f", msSnapshot),
+                String.format("%.2f", msCompute),
+                String.format("%.2f", msMerge),
+                String.format("%.2f", msConverge),
+                String.format("%.2f", msApply));
+
+            micaCumulativeReads = 0;
+            micaCumulativeWrites = 0;
+            micaCumulativeConflicts = 0;
+            micaCumulativeTainted = 0;
+            micaCumulativeReruns = 0;
+
+        }
+        // Mica end
+
+        // Run mid-tick tasks on the main thread
+        ((ca.spottedleaf.moonrise.patches.chunk_system.server.ChunkSystemMinecraftServer) this.level.getServer()).moonrise$executeMidTickTasks();
     }
+    // Mica end
     // Paper end - chunk tick iteration optimisations
 
 
