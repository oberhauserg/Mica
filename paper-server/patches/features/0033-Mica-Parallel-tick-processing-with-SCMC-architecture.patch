diff --git a/net/minecraft/server/level/mica/OverlayMerger.java b/net/minecraft/server/level/mica/OverlayMerger.java
new file mode 100644
index 0000000000000000000000000000000000000000..8955032d864a9b5f1686481c1cc4fe337dba9f44
--- /dev/null
+++ b/net/minecraft/server/level/mica/OverlayMerger.java
@@ -0,0 +1,180 @@
+// ============================================================================
+// 5. OverlayMerger
+// ============================================================================
+//
+// Purpose: Takes multiple TrackedOverlays from parallel workers,
+// detects conflicts, identifies tainted operations via provenance
+// graph walking, and produces either a clean merged result or
+// a set of operations that need serial re-execution.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.world.level.block.state.BlockState;
+import it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import java.util.*;
+
+public class OverlayMerger {
+
+    public record MergeResult(
+        // Clean writes that can be applied directly (no conflicts)
+        Long2ObjectMap<BlockState> cleanWrites,
+
+        // Operations that had conflicts and need serial re-execution
+        Set<OperationId> taintedOperations,
+
+        // Stats
+        int totalWrites,
+        int conflictCount,
+        int taintedOperationCount
+    ) {}
+
+    /**
+     * Merge multiple overlays, detect conflicts, and identify tainted operations.
+     *
+     * @param overlays The overlays from all worker threads
+     * @return MergeResult with clean writes and tainted operations
+     */
+    public static MergeResult merge(List<TrackedOverlay> overlays) {
+
+        // === Step 1: Find conflicting write positions ===
+        Long2IntOpenHashMap writeCountByPos = new Long2IntOpenHashMap();
+        writeCountByPos.defaultReturnValue(0);
+        Long2IntOpenHashMap singleWriterOverlay = new Long2IntOpenHashMap();
+        singleWriterOverlay.defaultReturnValue(-1);
+
+        int totalWritePositions = 0;
+
+        for (int i = 0; i < overlays.size(); i++) {
+            for (long pos : overlays.get(i).getBlockWrites().keySet()) {
+                int count = writeCountByPos.addTo(pos, 1);
+                if (count == 0) {
+                    singleWriterOverlay.put(pos, i);
+                    totalWritePositions++;
+                } else {
+                    singleWriterOverlay.remove(pos);
+                }
+            }
+        }
+
+        // === Fast path: no writes at all ===
+        if (totalWritePositions == 0) {
+            return new MergeResult(
+                new Long2ObjectOpenHashMap<>(),
+                new HashSet<>(),
+                0, 0, 0
+            );
+        }
+
+        // === Step 2: Separate clean writes from write-write conflicts ===
+        Long2ObjectMap<BlockState> cleanWrites = new Long2ObjectOpenHashMap<>();
+        Set<OperationId> taintedOps = new HashSet<>();
+        int conflictCount = 0;
+
+        for (var entry : singleWriterOverlay.long2IntEntrySet()) {
+            long pos = entry.getLongKey();
+            int overlayIndex = entry.getIntValue();
+            cleanWrites.put(pos, overlays.get(overlayIndex).getBlockWrites().get(pos));
+        }
+
+        for (var entry : writeCountByPos.long2IntEntrySet()) {
+            if (entry.getIntValue() > 1) {
+                long pos = entry.getLongKey();
+                conflictCount++;
+                for (TrackedOverlay overlay : overlays) {
+                    OperationId writer = overlay.getWriteProvenance().get(pos);
+                    if (writer != null) {
+                        taintedOps.add(writer);
+                    }
+                }
+            }
+        }
+
+        // === Step 3: Check for read-write conflicts ===
+        // Iterate writes (small set) and check if other overlays read those positions
+        for (int i = 0; i < overlays.size(); i++) {
+            TrackedOverlay writerOverlay = overlays.get(i);
+            for (var writeEntry : writerOverlay.getWriteProvenance().long2ObjectEntrySet()) {
+                long pos = writeEntry.getLongKey();
+                OperationId writer = writeEntry.getValue();
+
+                for (int j = 0; j < overlays.size(); j++) {
+                    if (i == j) continue;
+
+                    if (overlays.get(j).getReadPositions().contains(pos)) {
+                        // Taint the writer
+                        taintedOps.add(writer);
+
+                        // Find exactly which operations on the reading overlay read this position
+                        for (TrackedOverlay.ReadRecord record : overlays.get(j).getOperationReads()) {
+                            if (record.pos() == pos) {
+                                taintedOps.add(record.opId());
+                            }
+                        }
+                    }
+                }
+            }
+        }
+
+        // === Early exit: nothing tainted ===
+        if (taintedOps.isEmpty()) {
+            return new MergeResult(
+                cleanWrites,
+                taintedOps,
+                writeCountByPos.size(),
+                conflictCount,
+                0
+            );
+        }
+
+        // === Step 4: Transitive closure via targeted BFS ===
+        java.util.ArrayDeque<OperationId> worklist = new java.util.ArrayDeque<>(taintedOps);
+
+        while (!worklist.isEmpty()) {
+            OperationId tainted = worklist.poll();
+
+            // Find positions this tainted operation wrote to
+            for (TrackedOverlay overlay : overlays) {
+                for (var entry : overlay.getWriteProvenance().long2ObjectEntrySet()) {
+                    if (!entry.getValue().equals(tainted)) continue;
+
+                    long pos = entry.getLongKey();
+
+                    // Find operations that read this position across all overlays
+                    for (TrackedOverlay readerOverlay : overlays) {
+                        for (TrackedOverlay.ReadRecord record : readerOverlay.getOperationReads()) {
+                            if (record.pos() == pos && !taintedOps.contains(record.opId())) {
+                                taintedOps.add(record.opId());
+                                worklist.add(record.opId());
+                            }
+                        }
+                    }
+                }
+            }
+        }
+
+        // === Step 5: Remove tainted operations' writes from clean writes ===
+        for (TrackedOverlay overlay : overlays) {
+            for (var entry : overlay.getWriteProvenance().long2ObjectEntrySet()) {
+                if (taintedOps.contains(entry.getValue())) {
+                    cleanWrites.remove(entry.getLongKey());
+                }
+            }
+        }
+
+        return new MergeResult(
+            cleanWrites,
+            taintedOps,
+            writeCountByPos.size(),
+            conflictCount,
+            taintedOps.size()
+        );
+    }
+
+    private record WriteEntry(
+        int overlayIndex,
+        BlockState state,
+        OperationId source
+    ) {}
+}
