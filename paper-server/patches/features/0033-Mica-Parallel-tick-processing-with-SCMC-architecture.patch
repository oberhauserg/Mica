+        if (size == 0) return;
+
+        // --- Phase 1: Snapshot ---
+        long timeStart = System.nanoTime();
+
+        final net.minecraft.server.level.mica.WorldSnapshot snapshot =
+            net.minecraft.server.level.mica.WorldSnapshot.capture(world);
+
+        long timeSnapshot = System.nanoTime();
+
+        // --- Phase 2: Parallel Compute ---
+        // Initialize or reuse overlays
+        if (this.micaOverlays == null || this.micaOverlays.length < MICA_THREAD_COUNT) {
+            this.micaOverlays = new net.minecraft.server.level.mica.TrackedOverlay[MICA_THREAD_COUNT];
+        }
+        for (int t = 0; t < MICA_THREAD_COUNT; t++) {
