--- a/ca/spottedleaf/moonrise/patches/chunk_system/level/entity/EntityLookup.java
+++ b/ca/spottedleaf/moonrise/patches/chunk_system/level/entity/EntityLookup.java
@@ -1003,6 +1003,28 @@ public abstract class EntityLookup implements LevelEntityGetter<Entity> {
 
         @Override
         public void onRemove(final Entity.RemovalReason reason) {
+            // Mica start - defer entity removal during parallel execution
+            if (ca.spottedleaf.moonrise.common.util.TickThread.micaParallelPhase.get()) {
+                net.minecraft.server.level.mica.DeferredEffects deferred =
+                    net.minecraft.world.level.Level.micaDeferredStatic.get();
+                if (deferred != null) {
+                    final Entity removingEntity = this.entity;
+                    deferred.addDeferredTask(() -> {
+                        try {
+                            final Visibility tickingState = EntityLookup.getEntityStatus(removingEntity);
+                            EntityLookup.this.removeEntity(removingEntity);
+                            EntityLookup.this.entityStatusChange(removingEntity, null, tickingState, Visibility.HIDDEN, false, false, reason.shouldDestroy());
+                            EntityLookup.this.removeEntityCallback(removingEntity);
+                            removingEntity.setLevelCallback(NoOpCallback.INSTANCE);
+                        } catch (Throwable t) {
+                            // Entity state is stale — will self-correct
+                        }
+                    });
+                    return;
+                }
+            }
+            // Mica end
+
             final Entity entity = this.entity;
             EntityLookup.this.checkThread(entity, "Cannot remove entity off-main");
             final Visibility tickingState = EntityLookup.getEntityStatus(entity);
