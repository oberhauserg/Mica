+package net.minecraft.server.level.mica;
+
+import com.mojang.logging.LogUtils;
+import org.slf4j.Logger;
+
+import java.io.IOException;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.util.LinkedHashMap;
+import java.util.Map;
+
+/**
+ * Configuration for Mica parallel tick processing.
+ * Loaded from mica.yml in the server root directory.
+ */
+public final class MicaConfig {
+    private static final Logger LOGGER = org.slf4j.LoggerFactory.getLogger("Mica");
+    private static MicaConfig INSTANCE;
+
+    // === Config values ===
+    public boolean enabled = true;
+    public int threadCount = -1; // -1 = auto
+    public boolean parallelRandomTicks = true;
+    public boolean parallelEntityTicks = true;
+    public boolean parallelScheduledBlockTicks = true;
+    public boolean parallelScheduledFluidTicks = true;
+    public LogLevel logLevel = LogLevel.INFO;
+    public int statsInterval = 200;
+
+    private java.util.concurrent.ForkJoinPool pool;
+    private org.slf4j.Logger logger;
+
+    public enum LogLevel {
+        OFF, INFO, DEBUG, TRACE;
+
+        public boolean isAtLeast(LogLevel level) {
+            return this.ordinal() >= level.ordinal();
+        }
+    }
+
+    private MicaConfig() {}
+
+    /**
+     * Get the global Mica config instance.
+     */
+    public static MicaConfig get() {
+        if (INSTANCE == null) {
+            INSTANCE = new MicaConfig();
+        }
+        return INSTANCE;
+    }
+
+    public java.util.concurrent.ForkJoinPool getPool() {
+        if (this.pool == null) {
+            this.pool = new java.util.concurrent.ForkJoinPool(getThreadCount());
+        }
+        return this.pool;
+    }
+
+    public static org.slf4j.Logger getLogger() {
+        return LOGGER;
+    }
+
+    public boolean shouldLog(LogLevel level) {
+        return this.enabled && this.logLevel.isAtLeast(level);
+    }
+
+    /**
+     * Get the resolved thread count.
+     */
+    public int getThreadCount() {
+        if (this.threadCount <= 0) {
+            return Math.max(2, Runtime.getRuntime().availableProcessors() - 2);
+        }
+        return this.threadCount;
+    }
+
+    /**
+     * Configure the mica logger level.
+     */
+    public static void configureLogLevel() {
+        org.apache.logging.log4j.core.config.Configurator.setLevel("Mica",
+            switch (get().logLevel) {
+                case OFF -> org.apache.logging.log4j.Level.OFF;
+                case INFO -> org.apache.logging.log4j.Level.INFO;
+                case DEBUG -> org.apache.logging.log4j.Level.DEBUG;
+                case TRACE -> org.apache.logging.log4j.Level.TRACE;
+            }
+        );
+    }
+
+    /**
+     * Load config from mica.yml, creating it with defaults if it doesn't exist.
+     */
+    public static MicaConfig load(Path serverDir) {
+        MicaConfig config = new MicaConfig();
+        Path configPath = serverDir.resolve("mica.yml");
+
+        if (Files.exists(configPath)) {
+            try {
+                config.readFrom(configPath);
+            } catch (Exception e) {
+                LOGGER.error("Failed to load mica.yml, using defaults", e);
+            }
+        }
+
+        // Always write back - fills in missing keys with defaults
+        try {
+            config.writeTo(configPath);
+        } catch (Exception e) {
+            LOGGER.error("Failed to save mica.yml", e);
+        }
+
+        INSTANCE = config;
+
+        configureLogLevel();
+
+        LOGGER.info("Configuration loaded: enabled={}, threads={} (resolved={}), log-level={}",
+            config.enabled,
+            config.threadCount <= 0 ? "auto" : config.threadCount,
+            config.getThreadCount(),
+            config.logLevel);
+
+        if (config.enabled) {
+            StringBuilder subsystems = new StringBuilder("Parallel subsystems:");
+            if (config.parallelRandomTicks) subsystems.append(" random-ticks");
+            if (config.parallelEntityTicks) subsystems.append(" entity-ticks");
+            if (config.parallelScheduledBlockTicks) subsystems.append(" scheduled-block-ticks");
+            if (config.parallelScheduledFluidTicks) subsystems.append(" scheduled-fluid-ticks");
+            LOGGER.info(subsystems.toString());
+        } else {
+            LOGGER.info("Parallel processing is DISABLED - running as stock Paper");
+        }
+
+        return config;
+    }
+
+    /**
+     * Simple YAML reader - no dependency on external YAML libs.
+     * Handles flat and one-level nested keys only.
+     */
+    private void readFrom(Path path) throws IOException {
+        java.util.List<String> lines = Files.readAllLines(path);
+        String currentSection = null;
+
+        for (String rawLine : lines) {
+            // Strip comments
+            String line = rawLine;
+            int commentIdx = line.indexOf('#');
+            if (commentIdx >= 0 && (commentIdx == 0 || line.charAt(commentIdx - 1) == ' ')) {
+                line = line.substring(0, commentIdx);
+            }
+            line = line.stripTrailing();
+            if (line.isEmpty()) continue;
+
+            // Check indentation
+            String trimmed = line.stripLeading();
+            boolean indented = line.length() != trimmed.length();
+
+            int colonIdx = trimmed.indexOf(':');
+            if (colonIdx < 0) continue;
+
+            String key = trimmed.substring(0, colonIdx).strip();
+            String value = trimmed.substring(colonIdx + 1).strip();
+
+            if (value.isEmpty() && !indented) {
+                // Section header
+                currentSection = key;
+                continue;
+            }
+
+            String fullKey = indented && currentSection != null ? currentSection + "." + key : key;
+
+            switch (fullKey) {
+                case "enabled" -> this.enabled = parseBoolean(value, this.enabled);
+                case "threads" -> {
+                    if ("auto".equalsIgnoreCase(value)) {
+                        this.threadCount = -1;
+                    } else {
+                        try {
+                            int parsed = Integer.parseInt(value);
+                            this.threadCount = Math.max(1, parsed);
+                        } catch (NumberFormatException e) {
+                            this.threadCount = -1;
+                        }
+                    }
+                }
+                case "parallel.random-ticks" -> this.parallelRandomTicks = parseBoolean(value, this.parallelRandomTicks);
+                case "parallel.entity-ticks" -> this.parallelEntityTicks = parseBoolean(value, this.parallelEntityTicks);
+                case "parallel.scheduled-block-ticks" -> this.parallelScheduledBlockTicks = parseBoolean(value, this.parallelScheduledBlockTicks);
+                case "parallel.scheduled-fluid-ticks" -> this.parallelScheduledFluidTicks = parseBoolean(value, this.parallelScheduledFluidTicks);
+                case "log-level" -> {
+                    try {
+                        this.logLevel = LogLevel.valueOf(value.toUpperCase());
+                    } catch (IllegalArgumentException e) {
+                        this.logLevel = LogLevel.INFO;
+                    }
+                }
+                case "stats-interval" -> {
+                    try {
+                        this.statsInterval = Math.max(1, Integer.parseInt(value));
+                    } catch (NumberFormatException e) {
+                        this.statsInterval = 200;
+                    }
+                }
+            }
+        }
+    }
+
+    /**
+     * Write config to file with comments.
+     */
+    private void writeTo(Path path) throws IOException {
+        StringBuilder sb = new StringBuilder();
+        sb.append("# Mica - Parallel tick processing for Minecraft servers\n");
+        sb.append("\n");
+        sb.append("# Master switch - set to false to disable all parallel processing\n");
+        sb.append("# Server will behave identically to stock Paper\n");
+        sb.append("enabled: ").append(this.enabled).append("\n");
+        sb.append("\n");
+        sb.append("# Number of worker threads for parallel tick processing\n");
+        sb.append("# Default: auto (available processors - 2, minimum 2)\n");
+        sb.append("# Set to a specific number to override\n");
+        sb.append("threads: ").append(this.threadCount <= 0 ? "auto" : this.threadCount).append("\n");
+        sb.append("\n");
+        sb.append("# Per-subsystem toggles\n");
+        sb.append("# Disable individual subsystems if they cause issues\n");
+        sb.append("parallel:\n");
+        sb.append("  random-ticks: ").append(this.parallelRandomTicks).append("\n");
+        sb.append("  entity-ticks: ").append(this.parallelEntityTicks).append("\n");
+        sb.append("  scheduled-block-ticks: ").append(this.parallelScheduledBlockTicks).append("\n");
+        sb.append("  scheduled-fluid-ticks: ").append(this.parallelScheduledFluidTicks).append("\n");
+        sb.append("\n");
+        sb.append("# Logging level for Mica diagnostics\n");
+        sb.append("# OFF    - no Mica logging\n");
+        sb.append("# INFO   - periodic stats every stats-interval ticks (default)\n");
+        sb.append("# DEBUG  - per-collection logging, group details\n");
+        sb.append("# TRACE  - per-tick logging (very verbose, debugging only)\n");
+        sb.append("log-level: ").append(this.logLevel.name()).append("\n");
+        sb.append("\n");
+        sb.append("# Stats reporting interval in ticks (20 ticks = 1 second)\n");
+        sb.append("stats-interval: ").append(this.statsInterval).append("\n");
+
+        Files.writeString(path, sb.toString());
+    }
+
+    private static boolean parseBoolean(String value, boolean defaultValue) {
+        if ("true".equalsIgnoreCase(value)) return true;
+        if ("false".equalsIgnoreCase(value)) return false;
+        return defaultValue;
+    }
+}
