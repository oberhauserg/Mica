diff --git a/net/minecraft/server/level/mica/TickGrouper.java b/net/minecraft/server/level/mica/TickGrouper.java
new file mode 100644
index 0000000000000000000000000000000000000000..530ba2fcd12ab0857ec90908298954cf7d5de547
--- /dev/null
+++ b/net/minecraft/server/level/mica/TickGrouper.java
@@ -0,0 +1,174 @@
+// ============================================================================
+// TickGrouper
+// ============================================================================
+//
+// After parallel scheduled tick execution, groups ticks into independent
+// connected components based on their read/write/cascade overlap.
+// Components with no internal conflicts keep their parallel results.
+// Components with conflicts get re-run serially.
+//
+// Uses Union-Find (disjoint set) for efficient grouping.
+
+package net.minecraft.server.level.mica;
+
+import it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap;
+import it.unimi.dsi.fastutil.longs.LongOpenHashSet;
+import java.util.ArrayList;
+import java.util.HashSet;
+import java.util.List;
+import java.util.Set;
+
+public class TickGrouper {
+
+    /**
+     * Result of grouping: a list of tick groups, each marked as clean or tainted.
+     */
+    public record GroupResult(List<TickGroup> groups) {}
+
+    /**
+     * A group of tick indices that form a connected component.
+     * If tainted, the entire group must be re-run serially.
+     */
+    public record TickGroup(List<Integer> tickIndices, boolean tainted) {}
+
+    /**
+     * Union-Find with path compression and union by rank.
+     */
+    private static class UnionFind {
+        private final int[] parent;
+        private final int[] rank;
+
+        UnionFind(int size) {
+            parent = new int[size];
+            rank = new int[size];
+            for (int i = 0; i < size; i++) {
+                parent[i] = i;
+            }
+        }
+
+        int find(int x) {
+            if (parent[x] != x) {
+                parent[x] = find(parent[x]); // path compression
+            }
+            return parent[x];
+        }
+
+        void union(int a, int b) {
+            int ra = find(a);
+            int rb = find(b);
+            if (ra == rb) return;
+            // union by rank
+            if (rank[ra] < rank[rb]) {
+                parent[ra] = rb;
+            } else if (rank[ra] > rank[rb]) {
+                parent[rb] = ra;
+            } else {
+                parent[rb] = ra;
+                rank[ra]++;
+            }
+        }
+    }
+
+    /**
+     * Group ticks into connected components based on position overlap.
+     *
+     * Two ticks are in the same group if they share any position through:
+     * - Write-write overlap (both wrote to same position)
+     * - Write-read overlap (one wrote, other read same position)
+     * - Touched-read overlap (one's cascade touched a position the other read)
+     *
+     * @param overlays    The per-thread overlays from parallel execution
+     * @param tickCount   Total number of ticks that were dispatched
+     * @param threadCount Number of threads used
+     * @param batchSize   Size of each thread's batch (for mapping tick index → thread)
+     * @param taintedOps  Set of tainted OperationIds from the merger
+     * @param tickOpIds   Array mapping tick index → OperationId
+     */
+    public static GroupResult groupTicks(
+        List<TrackedOverlay> overlays,
+        int tickCount,
+        int threadCount,
+        int batchSize,
+        Set<OperationId> taintedOps,
+        OperationId[] tickOpIds
+    ) {
+        if (tickCount == 0) {
+            return new GroupResult(new ArrayList<>());
+        }
+
+        UnionFind uf = new UnionFind(tickCount);
+
+        // Build position → tick index mapping
+        // For each position that any tick wrote, read, or touched,
+        // record which tick indices are involved
+        Long2IntOpenHashMap positionToFirstTick = new Long2IntOpenHashMap();
+        positionToFirstTick.defaultReturnValue(-1);
+
+        for (int tickIdx = 0; tickIdx < tickCount; tickIdx++) {
+            int threadIdx = tickIdx / batchSize;
+            if (threadIdx >= threadCount) break;
+
+            TrackedOverlay overlay = overlays.get(threadIdx);
+            OperationId opId = tickOpIds[tickIdx];
+            if (opId == null) continue;
+
+            // Collect all positions this tick is involved with
+            LongOpenHashSet involvedPositions = new LongOpenHashSet();
+
+            // Positions this tick wrote
+            for (var entry : overlay.getWriteProvenance().long2ObjectEntrySet()) {
+                if (entry.getValue().equals(opId)) {
+                    involvedPositions.add(entry.getLongKey());
+                }
+            }
+
+            // Positions this tick read
+            for (TrackedOverlay.ReadRecord record : overlay.getOperationReads()) {
+                if (record.opId().equals(opId)) {
+                    involvedPositions.add(record.pos());
+                }
+            }
+
+            // Positions this tick's cascade touched
+            // (touchedPositions are per-overlay, not per-operation,
+            //  but during scheduled ticks each thread typically runs
+            //  one operation at a time, so they're effectively per-operation)
+
+            // Union this tick with any previous tick that shares a position
+            for (long pos : involvedPositions) {
+                int prev = positionToFirstTick.get(pos);
+                if (prev == -1) {
+                    positionToFirstTick.put(pos, tickIdx);
+                } else {
+                    uf.union(prev, tickIdx);
+                }
+            }
+        }
+
+        // Extract connected components
+        java.util.Map<Integer, List<Integer>> components = new java.util.HashMap<>();
+        for (int i = 0; i < tickCount; i++) {
+            int root = uf.find(i);
+            components.computeIfAbsent(root, k -> new ArrayList<>()).add(i);
+        }
+
+        // Determine which components are tainted
+        List<TickGroup> groups = new ArrayList<>();
+        for (var entry : components.entrySet()) {
+            List<Integer> indices = entry.getValue();
+            boolean groupTainted = false;
+
+            for (int idx : indices) {
+                OperationId opId = tickOpIds[idx];
+                if (opId != null && taintedOps.contains(opId)) {
+                    groupTainted = true;
+                    break;
+                }
+            }
+
+            groups.add(new TickGroup(indices, groupTainted));
+        }
+
+        return new GroupResult(groups);
+    }
+}
