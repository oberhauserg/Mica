diff --git a/net/minecraft/server/level/ServerLevel.java b/net/minecraft/server/level/ServerLevel.java
index f1ae45545e87e396089ab4820ee03f41b0edca26..a1135dc02b24a36c230258cf1be30129a75de78f 100644
--- a/net/minecraft/server/level/ServerLevel.java
+++ b/net/minecraft/server/level/ServerLevel.java
@@ -751,7 +751,260 @@ public class ServerLevel extends Level implements ServerEntityGetter, WorldGenLe
         return this.environmentAttributes;
     }
 
+    // Mica start - raw block write for apply phase, no game logic triggers
+    public void micaRawSetBlock(BlockPos pos, BlockState state) {
+        LevelChunk chunk = this.getChunkAt(pos);
+        int sectionIndex = this.getSectionIndex(pos.getY());
+        LevelChunkSection section = chunk.getSections()[sectionIndex];
+
+        if (section == null) return;
+
+        section.setBlockState(pos.getX() & 15, pos.getY() & 15, pos.getZ() & 15, state);
+
+        // Notify clients
+        this.getChunkSource().blockChanged(pos);
+        // Mark chunk dirty for saving
+        chunk.markUnsaved();
+    }
+    // Mica end
+
+    // Mica start - parallel scheduled tick dispatch
+
+    public long micaScheduledTickCumTaint = 0;
+    public long micaScheduledTickCumConf = 0;
+
+    private <T> void micaRunScheduledTicks(java.util.List<net.minecraft.world.ticks.ScheduledTick<T>> ticks, boolean isBlockTick) {
+        final int threadCount = ServerChunkCache.MICA_THREAD_COUNT;
+        final net.minecraft.server.level.mica.WorldSnapshot snapshot = net.minecraft.server.level.mica.WorldSnapshot.capture(this);
+
+        final net.minecraft.server.level.mica.TrackedOverlay[] overlays =
+            new net.minecraft.server.level.mica.TrackedOverlay[threadCount];
+        for (int t = 0; t < threadCount; t++) {
+            overlays[t] = new net.minecraft.server.level.mica.TrackedOverlay(snapshot);
+            overlays[t].deferredEffects = new net.minecraft.server.level.mica.DeferredEffects();
+            overlays[t].setThreadIndex(t);
+        }
+
+        // Map tick positions to OperationIds for original-order re-run
+        final java.util.concurrent.ConcurrentHashMap<Long, net.minecraft.server.level.mica.OperationId> tickPosToOp =
+            new java.util.concurrent.ConcurrentHashMap<>();
+
+        final int batchSize = Math.max(1, (ticks.size() + threadCount - 1) / threadCount);
+        final java.util.concurrent.CountDownLatch latch = new java.util.concurrent.CountDownLatch(threadCount);
+        final java.util.concurrent.atomic.AtomicReference<Throwable> error = new java.util.concurrent.atomic.AtomicReference<>();
+
+        for (int t = 0; t < threadCount; t++) {
+            final int threadIndex = t;
+            final int start = t * batchSize;
+            final int end = Math.min(start + batchSize, ticks.size());
+
+            if (start >= ticks.size()) {
+                latch.countDown();
+                continue;
+            }
+
+            final net.minecraft.server.level.mica.TrackedOverlay overlay = overlays[t];
+
+            ServerChunkCache.MICA_POOL.execute(() -> {
+                try {
+                    ca.spottedleaf.moonrise.common.util.TickThread.micaParallelPhase.set(Boolean.TRUE);
+                    this.micaOverlay.set(overlay);
+                    net.minecraft.world.level.Level.micaDeferredStatic.set(overlay.deferredEffects);
+
+                    alternate.current.wire.WireHandler threadWireHandler = new alternate.current.wire.WireHandler(this);
+                    Level.micaWireHandler.set(threadWireHandler);
+
+                    net.minecraft.world.level.redstone.CollectingNeighborUpdater threadUpdater =
+                        new net.minecraft.world.level.redstone.CollectingNeighborUpdater(
+                            this, this.getServer().getMaxChainedNeighborUpdates());
+                    net.minecraft.world.level.Level.micaNeighborUpdater.set(threadUpdater);
+
+                    try {
+                        for (int i = start; i < end; i++) {
+                            net.minecraft.world.ticks.ScheduledTick<T> tick = ticks.get(i);
+
+                            net.minecraft.server.level.mica.OperationId opId = isBlockTick
+                                ? net.minecraft.server.level.mica.OperationId.blockTick(tick.pos(), threadIndex)
+                                : net.minecraft.server.level.mica.OperationId.fluidTick(tick.pos(), threadIndex);
+                            overlay.setCurrentOperation(opId);
+                            overlay.deferredEffects.setCurrentOperation(opId);
+                            overlay.recordTick(opId, tick.pos());
+                            tickPosToOp.put(tick.pos().asLong(), opId);
+
+                            if (isBlockTick) {
+                                net.minecraft.world.level.block.state.BlockState state = this.getBlockState(tick.pos());
+                                if (state.is((net.minecraft.world.level.block.Block) tick.type())) {
+                                    state.tick(this, tick.pos(), this.random);
+                                }
+                            } else {
+                                net.minecraft.world.level.block.state.BlockState blockState = this.getBlockState(tick.pos());
+                                net.minecraft.world.level.material.FluidState fluidState = blockState.getFluidState();
+                                if (fluidState.is((net.minecraft.world.level.material.Fluid) tick.type())) {
+                                    fluidState.tick(this, tick.pos(), blockState);
+                                }
+                            }
+                        }
+                    } finally {
+                        ca.spottedleaf.moonrise.common.util.TickThread.micaParallelPhase.set(Boolean.FALSE);
+                        this.micaOverlay.remove();
+                        Level.micaWireHandler.remove();
+                        net.minecraft.world.level.Level.micaDeferredStatic.remove();
+                        net.minecraft.world.level.Level.micaNeighborUpdater.remove();
+                    }
+                } catch (Throwable t1) {
+                    error.compareAndSet(null, t1);
+                    ServerChunkCache.MICA_LOGGER.error("[Mica] Error in parallel scheduled tick on thread {}", threadIndex, t1);
+                } finally {
+                    latch.countDown();
+                }
+            });
+        }
+
+        try {
+            latch.await();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+        }
+
+        if (error.get() != null) {
+            ServerChunkCache.MICA_LOGGER.error("[Mica] Scheduled tick had errors");
+            return;
+        }
+
+        // Merge overlays
+        java.util.List<net.minecraft.server.level.mica.TrackedOverlay> activeOverlays =
+            java.util.Arrays.asList(overlays).subList(0, threadCount);
+        net.minecraft.server.level.mica.OverlayMerger.MergeResult mergeResult =
+            net.minecraft.server.level.mica.OverlayMerger.merge(activeOverlays);
+
+        ServerChunkCache.MICA_LOGGER.info("[Mica/Scheduled] collected {} ticks, {} tainted",
+            ticks.size(), mergeResult.taintedOperationCount());
+
+        // Replay deferred scheduled ticks — but only if no re-run happened
+        if (!mergeResult.taintedOperations().isEmpty()) {
+            ServerChunkCache.MICA_LOGGER.info("[Mica/Scheduled] TAINTED — re-running {} ticks serially", ticks.size());
+            // Discard ALL parallel results — run everything serially against the live world
+            // This is identical to vanilla execution
+            for (var tick : ticks) {
+                if (isBlockTick) {
+                    net.minecraft.world.level.block.state.BlockState state = this.getBlockState(tick.pos());
+                    if (state.is((net.minecraft.world.level.block.Block) tick.type())) {
+                        state.tick(this, tick.pos(), this.random);
+                    }
+                } else {
+                    net.minecraft.world.level.block.state.BlockState blockState = this.getBlockState(tick.pos());
+                    net.minecraft.world.level.material.FluidState fluidState = blockState.getFluidState();
+                    if (fluidState.is((net.minecraft.world.level.material.Fluid) tick.type())) {
+                        fluidState.tick(this, tick.pos(), blockState);
+                    }
+                }
+            }
+        }
+        else {
+            int deferredTickCount = 0;
+            for (int t = 0; t < threadCount; t++) {
+                if (overlays[t].deferredEffects != null) {
+                    deferredTickCount += overlays[t].deferredEffects.getScheduledTicks().size();
+                }
+            }
+            ServerChunkCache.MICA_LOGGER.info("[Mica/Scheduled] CLEAN — {} writes, {} deferred ticks",
+                mergeResult.cleanWrites().size(), deferredTickCount);
+            // Apply ALL writes to live world (single pass)
+            for (var entry : mergeResult.cleanWrites().long2ObjectEntrySet()) {
+                net.minecraft.core.BlockPos pos = net.minecraft.core.BlockPos.of(entry.getLongKey());
+                this.micaRawSetBlock(pos, entry.getValue());
+            }
+
+            // Replay deferred scheduled ticks
+            for (int t = 0; t < threadCount; t++) {
+                if (overlays[t].deferredEffects != null) {
+                    for (var st : overlays[t].deferredEffects.getScheduledTicks()) {
+                        if (st.isBlock()) {
+                            this.getBlockTicks().schedule((net.minecraft.world.ticks.ScheduledTick) st.tick());
+                        } else {
+                            this.getFluidTicks().schedule((net.minecraft.world.ticks.ScheduledTick) st.tick());
+                        }
+                    }
+                }
+            }
+
+            // Apply deferred effects
+            for (int t = 0; t < threadCount; t++) {
+                if (overlays[t].deferredEffects != null && !overlays[t].deferredEffects.isEmpty()) {
+                    overlays[t].deferredEffects.apply(this);
+                }
+            }
+
+            // Collect and execute ticks due for this game tick serially
+            // Mica - drain same-tick cascades until stable
+            if (isBlockTick) {
+                long currentTick = this.getGameTime();
+                while (true) {
+                    java.util.List<net.minecraft.world.ticks.ScheduledTick<net.minecraft.world.level.block.Block>> cascadeTicks =
+                        ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.block.Block>) this.getBlockTicks())
+                            .collectForParallelDispatch(currentTick, 65536);
+                    if (cascadeTicks.isEmpty()) {
+                        ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.block.Block>) this.getBlockTicks())
+                            .finishParallelDispatch();
+                        break;
+                    }
+                    for (var tick : cascadeTicks) {
+                        net.minecraft.world.level.block.state.BlockState state = this.getBlockState(tick.pos());
+                        if (state.is((net.minecraft.world.level.block.Block) tick.type())) {
+                            state.tick(this, tick.pos(), this.random);
+                        }
+                    }
+                    ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.block.Block>) this.getBlockTicks())
+                        .finishParallelDispatch();
+                }
+            } else {
+                long currentTick = this.getGameTime();
+                while (true) {
+                    java.util.List<net.minecraft.world.ticks.ScheduledTick<net.minecraft.world.level.material.Fluid>> cascadeTicks =
+                        ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.material.Fluid>) this.getFluidTicks())
+                            .collectForParallelDispatch(currentTick, 65536);
+                    if (cascadeTicks.isEmpty()) {
+                        ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.material.Fluid>) this.getFluidTicks())
+                            .finishParallelDispatch();
+                        break;
+                    }
+                    for (var tick : cascadeTicks) {
+                        net.minecraft.world.level.block.state.BlockState blockState = this.getBlockState(tick.pos());
+                        net.minecraft.world.level.material.FluidState fluidState = blockState.getFluidState();
+                        if (fluidState.is((net.minecraft.world.level.material.Fluid) tick.type())) {
+                            fluidState.tick(this, tick.pos(), blockState);
+                        }
+                    }
+                    ((net.minecraft.world.ticks.LevelTicks<net.minecraft.world.level.material.Fluid>) this.getFluidTicks())
+                        .finishParallelDispatch();
+                }
+            }
+
+        }
+
+        // Log stats
+        micaScheduledTickCumTaint += mergeResult.taintedOperationCount();
+        micaScheduledTickCumConf += mergeResult.conflictCount();
+
+        this.micaScheduledTickCount++;
+        if (this.micaScheduledTickCount % 200 == 0) {
+            int totalReads = 0, totalWrites = 0;
+            for (int t = 0; t < threadCount; t++) {
+                totalReads += overlays[t].getReadCount();
+                totalWrites += overlays[t].getWriteCount();
+            }
+            ServerChunkCache.MICA_LOGGER.info("[Mica/Scheduled] {} | {} threads | {} ticks | {} reads, {} writes | {} conflicts, {} tainted",
+                isBlockTick ? "blocks" : "fluids",
+                threadCount, ticks.size(), totalReads, totalWrites,
+                micaScheduledTickCumConf, micaScheduledTickCumTaint);
+            micaScheduledTickCumConf = 0;
+            micaScheduledTickCumTaint = 0;
+        }
+    }
+
+    public long micaScheduledTickCount = 0;
     public long micaEntityTickCount = 0;
+    // Mica end
 
