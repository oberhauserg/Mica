+    // Change the record to include the source operation
+    public record DeferredScheduledTick(net.minecraft.world.ticks.ScheduledTick<?> tick, boolean isBlock,
+                                        net.minecraft.server.level.mica.OperationId sourceOp) {}
+
+    private final List<DeferredScheduledTick> scheduledTicks = new ArrayList<>();
+
+    // Add a field to track current operation
+    private @Nullable OperationId currentOperation;
+
+    public void setCurrentOperation(@Nullable OperationId op) {
+        this.currentOperation = op;
+    }
+
+    // Update addScheduledTick to tag with current operation
+    public <T> void addScheduledTick(net.minecraft.world.ticks.ScheduledTick<T> tick, boolean isBlock) {
+        this.scheduledTicks.add(new DeferredScheduledTick(tick, isBlock, this.currentOperation));
+    }
