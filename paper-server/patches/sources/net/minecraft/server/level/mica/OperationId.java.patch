+// ============================================================================
+// 3. OperationId
+// ============================================================================
+//
+// Purpose: Unique identifier for a single tick operation.
+// Used for provenance tracking — "which operation read/wrote this position?"
+// Lightweight value object.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.core.BlockPos;
+
+public record OperationId(
+    OperationType type,
+    long sourcePos,      // packed BlockPos or entity ID, depending on type
+    int threadIndex      // which worker thread ran this operation
+) {
+    /**
+     * Create an ID for a scheduled block tick operation.
+     */
+    public static OperationId blockTick(BlockPos pos, int threadIndex) {
+        return new OperationId(OperationType.BLOCK_TICK, pos.asLong(), threadIndex);
+    }
+
+    /**
+     * Create an ID for a chunk tick operation (random ticks, ice/snow).
+     */
+    public static OperationId chunkTick(long chunkPos, int threadIndex) {
+        return new OperationId(OperationType.CHUNK_TICK, chunkPos, threadIndex);
+    }
+
+    /**
+     * Create an ID for a scheduled fluid tick operation.
+     */
+    public static OperationId fluidTick(BlockPos pos, int threadIndex) {
+        return new OperationId(OperationType.FLUID_TICK, pos.asLong(), threadIndex);
+    }
+
+    /**
+     * Create an ID for a random block tick in a chunk.
+     */
+    public static OperationId randomTick(BlockPos pos, int threadIndex) {
+        return new OperationId(OperationType.RANDOM_TICK, pos.asLong(), threadIndex);
+    }
+
+    /**
+     * Create an ID for an entity tick.
+     */
+    public static OperationId entityTick(int entityId, int threadIndex) {
+        return new OperationId(OperationType.ENTITY_TICK, entityId, threadIndex);
+    }
+
+    /**
+     * Create an ID for a block entity tick.
+     */
+    public static OperationId blockEntityTick(BlockPos pos, int threadIndex) {
+        return new OperationId(OperationType.BLOCK_ENTITY_TICK, pos.asLong(), threadIndex);
+    }
+}
