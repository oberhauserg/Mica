+// ============================================================================
+// WorldSnapshot
+// ============================================================================
+//
+// Purpose: Immutable view of world state at tick start.
+// All parallel workers read from this. Nobody writes to it.
+//
+// Key design decision: We don't deep-copy the world. We use Copy-on-Write
+// at the chunk section level. At tick start, we flag all loaded chunk
+// sections as COW. If the merge phase (or anything else) needs to write
+// to a section, it copies it first. Snapshot readers always see the
+// original data.
+//
+// Implements BlockGetter so existing Minecraft code that reads block state
+// can accept it without modification.
+
+package net.minecraft.server.level.mica;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.world.level.BlockGetter;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.level.chunk.LevelChunk;
+import net.minecraft.world.level.chunk.LevelChunkSection;
+import net.minecraft.world.level.material.FluidState;
+import net.minecraft.server.level.ServerLevel;
+import it.unimi.dsi.fastutil.longs.Long2ObjectMap;
+import it.unimi.dsi.fastutil.longs.Long2ObjectOpenHashMap;
+import org.jspecify.annotations.Nullable;
+
+public class WorldSnapshot implements BlockGetter {
+
+    // Snapshotted chunk sections, keyed by chunk pos
+    // Each entry holds references to the section arrays AT THE TIME of snapshot
+    // These references become stale if the live world modifies them,
+    // but that's the point — we want the old data
+    private final Long2ObjectMap<LevelChunkSection[]> sectionSnapshots;
+
+    // Reference to the live world for data we don't snapshot
+    // (biomes, heightmaps, light — these change rarely mid-tick
+    // and are expensive to snapshot)
+    private final ServerLevel level;
+
+    // The game tick this snapshot represents
+    private final long gameTick;
+
+    private WorldSnapshot(ServerLevel level, long gameTick,
+                          Long2ObjectMap<LevelChunkSection[]> sectionSnapshots) {
+        this.level = level;
+        this.gameTick = gameTick;
+        this.sectionSnapshots = sectionSnapshots;
+    }
+
+    /**
+     * Create a snapshot of the current world state.
+     *
+     * This is O(number of loaded chunks) but very fast —
+     * we're just copying array references, not block data.
+     * Each LevelChunkSection is ~8KB of palette-compressed data;
+     * we only reference it, not copy it.
+     */
+    public static WorldSnapshot capture(ServerLevel level) {
+        long gameTick = level.getGameTime();
+        Long2ObjectMap<LevelChunkSection[]> sections = new Long2ObjectOpenHashMap<>();
+
+        // Iterate all entity-ticking chunks (the ones that get ticked)
+        // Paper gives us direct array access for performance
+        var tickingChunks = level.moonrise$getEntityTickingChunks();
+        LevelChunk[] raw = tickingChunks.getRawDataUnchecked();
+        int size = tickingChunks.size();
+
+        for (int i = 0; i < size; i++) {
+            LevelChunk chunk = raw[i];
+            long chunkKey = chunk.getPos().toLong();
+
+            // Snapshot the section array reference
+            // IMPORTANT: We store a reference to the SAME array.
+            // If we later need COW, we clone at that point.
+            LevelChunkSection[] original = chunk.getSections();
+            LevelChunkSection[] copy = new LevelChunkSection[original.length];
+            System.arraycopy(original, 0, copy, 0, original.length);
+            sections.put(chunkKey, copy);
+        }
+
+        return new WorldSnapshot(level, gameTick, sections);
+    }
+
+    @Override
+    public @Nullable BlockState getBlockState(BlockPos pos) {
+        int chunkX = pos.getX() >> 4;
+        int chunkZ = pos.getZ() >> 4;
+        long chunkKey = ((long) chunkX & 0xFFFFFFFFL) | (((long) chunkZ & 0xFFFFFFFFL) << 32);
+
+        LevelChunkSection[] sections = this.sectionSnapshots.get(chunkKey);
+        if (sections == null) {
+            // Chunk not in snapshot — fall back to live world
+            // This handles edge cases where an operation reads beyond
+            // the ticking chunk radius
+
+            // Bypass Level.getBlockState() to avoid hitting the Mica overlay intercept
+            LevelChunk chunk = this.level.getChunkSource().getChunkAtIfLoadedImmediately(pos.getX() >> 4, pos.getZ() >> 4);
+            if (chunk != null) {
+                return chunk.getBlockState(pos);
+            }
+            return net.minecraft.world.level.block.Blocks.AIR.defaultBlockState();
+        }
+
+        int sectionIndex = level.getSectionIndex(pos.getY());
+        if (sectionIndex < 0 || sectionIndex >= sections.length) {
+            // Out of world bounds
+            return net.minecraft.world.level.block.Blocks.AIR.defaultBlockState();
+        }
+
+        LevelChunkSection section = sections[sectionIndex];
+        return section.getBlockState(
+            pos.getX() & 15,
+            pos.getY() & 15,
+            pos.getZ() & 15
+        );
+    }
+
+    @Override
+    public @Nullable FluidState getFluidState(BlockPos pos) {
+        BlockState state = this.getBlockState(pos);
+        return state.getFluidState();
+    }
+
+    @Override
+    public @Nullable FluidState getFluidIfLoaded(BlockPos pos) {
+        return this.getFluidState(pos);
+    }
+
+    @Override
+    public @Nullable BlockEntity getBlockEntity(BlockPos pos) {
+        // Block entities are more complex — for now, delegate to live world
+        // This is safe for snapshot reads because block entity state
+        // doesn't change during the compute phase
+        // TODO: Snapshot block entity state for full isolation
+        return this.level.getBlockEntity(pos);
+    }
+
+    @Override
+    public @Nullable BlockState getBlockStateIfLoaded(BlockPos pos) {
+        return this.getBlockState(pos);
+    }
+
+    @Override
+    public int getHeight() {
+        return this.level.getHeight();
+    }
+
+    @Override
+    public int getMinY() {
+        return this.level.getMinY();
+    }
+
+    public long getGameTick() {
+        return this.gameTick;
+    }
+
+    public ServerLevel getLevel() {
+        return this.level;
+    }
+}
+
